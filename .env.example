# MongoDB connection string (Atlas or self-hosted). Leave unset to run in demo mode
# with seed data only (directory listings) and no persistence for submissions/prompts.
MONGODB_URI=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-string

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# (Create Credentials > OAuth client ID > Web application). Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google        (local dev)
#   https://your-domain.com/api/auth/callback/google      (production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — create at https://github.com/settings/developers
# (New OAuth App). Authorization callback URL:
#   http://localhost:3000/api/auth/callback/github        (local dev)
#   https://your-domain.com/api/auth/callback/github      (production)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# No values above? In development (NODE_ENV != production) the login page
# also shows a "Connexion de test" form (email/name only, no OAuth needed)
# so you can test the auth-gated flows without registering real apps.
# It's automatically disabled in production.
